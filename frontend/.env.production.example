# Backend API Configuration  
VITE_API_BASE_URL=https://api.your-production-domain.com/api
VITE_SOCKET_URL=https://api.your-production-domain.com

# Clerk Authentication Configuration
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your_publishable_key
VITE_CLERK_SIGN_IN_URL=/login
VITE_CLERK_SIGN_UP_URL=/signup
VITE_CLERK_AFTER_SIGN_IN_URL=/
VITE_CLERK_AFTER_SIGN_UP_URL=/

# Feature Flags
VITE_ENABLE_PWA=true
VITE_ENABLE_NOTIFICATIONS=true

# Production Mode
VITE_NODE_ENV=production

# Media & API Configuration
VITE_UPLOAD_TIMEOUT_MS=300000
VITE_API_TIMEOUT_MS=10000
