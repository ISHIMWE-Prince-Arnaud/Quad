# Server Configuration
PORT=4000
NODE_ENV=production

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxx.mongodb.net/quad?retryWrites=true&w=majority

# Auth (Clerk)
CLERK_PUBLISHABLE_KEY=pk_live_your_publishable_key
CLERK_SECRET_KEY=sk_live_your_secret_key
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Indexes
SKIP_INDEX_CREATION=false

# CORS Config
FRONTEND_URL=https://your-production-frontend-domain.com

# Rate Limiting
RATE_LIMIT_GENERAL_WINDOW_MS=60000
RATE_LIMIT_GENERAL_MAX=500
RATE_LIMIT_SEARCH_WINDOW_MS=900000
RATE_LIMIT_SEARCH_MAX=200
RATE_LIMIT_UPLOAD_WINDOW_MS=900000
RATE_LIMIT_UPLOAD_MAX=60
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_WRITE_WINDOW_MS=60000
RATE_LIMIT_WRITE_MAX=120

# Server & Media Configuration
SERVER_TIMEOUT_MS=300000
UPLOAD_MAX_FILE_SIZE_BYTES=1073741824
IMAGE_MAX_FILE_SIZE_BYTES=10485760
CLOUDINARY_TIMEOUT_MS=300000

# Socket.IO Configuration
SOCKET_PING_TIMEOUT_MS=60000
SOCKET_PING_INTERVAL_MS=25000
